# Copy to apps/web/.env.local and fill in. Never commit a real .env file.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...                 # from `supabase status`
SUPABASE_SERVICE_ROLE_KEY=ey...                     # server-only, never exposed

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# === Google Maps (Phase 5) ===
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_KEY=

# === Google Cloud Translation (admin CMS auto-translate from Arabic) ===
# Server-only key for the Google Cloud Translation v2 API. Enable
# "Cloud Translation API" in the same Google Cloud project as Maps.
GOOGLE_TRANSLATE_API_KEY=

# === Verification providers (Phase 3 integration) ===
# Leave empty in local/preview — mock adapters are used until set.
SMS_PROVIDER=mock                                   # mock | taqnyat | unifonic | twilio
SMS_API_KEY=
WHATSAPP_API_TOKEN=
NAFATH_API_BASE=
NAFATH_CLIENT_ID=
NAFATH_CLIENT_SECRET=

# === Payments (Phase 9) ===
PAYMENTS_PROVIDER=                                  # tap | moyasar | hyperpay
PAYMENTS_API_SECRET=
PAYMENTS_WEBHOOK_SECRET=

# === Monitoring ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                                  # CI only
