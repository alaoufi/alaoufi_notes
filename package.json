{
  "name": "syanah",
  "version": "0.1.0",
  "private": true,
  "description": "Syanah maintenance services marketplace - monorepo root",
  "scripts": {
    "dev": "pnpm --filter @syanah/web dev",
    "build": "pnpm --filter @syanah/web build",
    "start": "pnpm --filter @syanah/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}
